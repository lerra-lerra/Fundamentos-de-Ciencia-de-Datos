#PARTE A
# Calcule la probabilidad de que 5 de los huevos parasitos sean removidos
#del nido si se sabe que el nido parasitado es de la especie aceptadora.
#CUADERNO- SE PUEDE CALCULAR CON DBINOM (DISTRIBUCION BINOMIAL)
pY0<-0.9
pr0<-0.3
dbinom(5,8, pr0)
#Calcule la probabilidad de que x de los huevos ajenos sean removidos del nido
#si sesabe que el nido parasitado es de la especie aceptadora, para 0 â¤ x â¤ 8,
#y represente las probabilidades calculadas en un diagrama de barras. Incluya un
#tÄ±tulo pertinente en el grÌafico
proba_aceptadora<-rep(0,9)
for (i in 0:8) {
proba_aceptadora[i+1]<-dbinom(i,8,pr0)
}
