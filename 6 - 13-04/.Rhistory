promedio_vecinos <-function(x,y,xnew, vecinos_cantidad ){
df <- data.frame(altura,altura_madres)
df$resta = abs(df$altura_madres-xnew)
df[order(df$resta),c(1,2,3)]
mean(df[1:vecinos_cantidad,1])
}
